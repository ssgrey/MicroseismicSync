<Window x:Class="MicroseismicSync.MonitorSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="监控设置"
        Width="320"
        Height="170"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="定时获取后端数据间隔（秒）" />

        <TextBox x:Name="IntervalTextBox" Height="26" VerticalContentAlignment="Center"
                 Grid.Row="1" ToolTip="请输入大于 0 的整数。"
                 Margin="0,10,0,0" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="72" Height="26"
                    Margin="0,12,8,0"
                    Click="OnOkButtonClick"
                    Content="确定"
                    IsDefault="True" />
            <Button Width="72"
                    Margin="0,12,0,0"
                    Content="取消"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
