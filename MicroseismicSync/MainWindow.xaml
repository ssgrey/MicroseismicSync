<Window x:Class="MicroseismicSync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MicroseismicSync"
        mc:Ignorable="d" Background="#FFF0F0F0"
        Title="微地震数据同步"
        Height="820"
        Width="1360"
        MinHeight="720"
        MinWidth="1120"
        Loaded="Window_OnLoaded"
        DataContextChanged="Window_OnDataContextChanged"
        Closed="Window_OnClosed">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="FileGridTextColumnElementStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="26" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="10,1,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="0,0,0,8" x:Name="menu">
            <MenuItem Header="同步"
                      Visibility="{Binding IsUploadTabActive, Converter={StaticResource BoolToVisibilityConverter}}">
                <MenuItem Header="开始同步"
                          Command="{Binding StartSyncCommand}" />
                <MenuItem Header="停止同步"
                          Command="{Binding StopSyncCommand}" />
            </MenuItem>
            <MenuItem Header="后端监控"
                      Visibility="{Binding IsBackendTabActive, Converter={StaticResource BoolToVisibilityConverter}}">
                <MenuItem Header="开始监控"
                          Command="{Binding StartBackendMonitorCommand}" />
                <MenuItem Header="停止监控"
                          Command="{Binding StopBackendMonitorCommand}" />
                <Separator />
                <MenuItem Header="监控设置"
                          Command="{Binding OpenBackendMonitorSettingsCommand}" />
            </MenuItem>
        </Menu>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding ActiveTabIndex}">
            <TabItem Header="本地同步">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14"
                            Margin="0,0,0,12"
                            Background="#FFF7FAFC"
                            BorderBrush="#FFD7E3EF"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayProjectName}" />

                            <ComboBox Grid.Column="2"
                                      Height="26"
                                      DisplayMemberPath="WellName"
                                      ItemsSource="{Binding Wells}"
                                      SelectedItem="{Binding SelectedWell}"
                                      IsEnabled="{Binding CanChangeSelectedWell}"
                                      IsSynchronizedWithCurrentItem="False" />

                            <!--<Button Grid.Column="4"
                                    Width="26"
                                    Height="26"
                                    Command="{Binding LoadWellsCommand}"
                                    Content="⟳" />-->

                            <StackPanel Grid.Column="6" HorizontalAlignment="Right">
                                <TextBlock HorizontalAlignment="Right"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedWellText}" />
                                <TextBlock Margin="0,4,0,0"
                                           HorizontalAlignment="Right"
                                           Foreground="#FF64748B"
                                           Text="{Binding BusyMessage}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="SGY">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{Binding SgyPanel.FolderPathInput, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="支持本地路径或 UNC 共享路径，例如 \\server\share\folder；停止输入 3 秒后自动应用" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Command="{Binding SgyPanel.SelectFolderCommand}"
                                            ToolTip="选择文件夹" Content="..." />
                                </Grid>

                                <DataGrid x:Name="SgyDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow"
                                          ItemsSource="{Binding SgyPanel.Files}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="手动同步选中项"
                                                      Click="ManualSyncSelectedMenuItem_OnClick"
                                                      Tag="SGY" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="25" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding FileName}"
                                                            Header="文件名"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="120"
                                                            Binding="{Binding CreationTime, StringFormat=yyyy/MM/dd HH:mm:ss}"
                                                            Header="创建时间"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="60"
                                                            Binding="{Binding FileSizeDisplay}"
                                                            Header="大小"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="70"
                                                            Binding="{Binding SyncStatus}"
                                                            Header="状态"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="ESF">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{Binding EsfPanel.FolderPathInput, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="支持本地路径或 UNC 共享路径，例如 \\server\share\folder；停止输入 3 秒后自动应用" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Command="{Binding EsfPanel.SelectFolderCommand}"
                                             ToolTip="选择文件夹" Content="..." />
                                </Grid>

                                <DataGrid x:Name="EsfDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow"
                                          ItemsSource="{Binding EsfPanel.Files}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="手动同步选中项"
                                                      Click="ManualSyncSelectedMenuItem_OnClick"
                                                      Tag="ESF" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="25" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding FileName}"
                                                            Header="文件名"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="120"
                                                            Binding="{Binding CreationTime, StringFormat=yyyy/MM/dd HH:mm:ss}"
                                                            Header="创建时间"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="60"
                                                            Binding="{Binding FileSizeDisplay}"
                                                            Header="大小"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="70"
                                                            Binding="{Binding SyncStatus}"
                                                            Header="状态"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Column="4" Header="CSV">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{Binding CsvPanel.FolderPathInput, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="支持本地路径或 UNC 共享路径，例如 \\server\share\folder；停止输入 3 秒后自动应用" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Command="{Binding CsvPanel.SelectFolderCommand}"
                                            ToolTip="选择文件夹" Content="..." />
                                </Grid>

                                <DataGrid x:Name="CsvDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow"
                                          ItemsSource="{Binding CsvPanel.Files}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="手动同步选中项"
                                                      Click="ManualSyncSelectedMenuItem_OnClick"
                                                      Tag="CSV" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="25" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding FileName}"
                                                            Header="文件名"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="120"
                                                            Binding="{Binding CreationTime, StringFormat=yyyy/MM/dd HH:mm:ss}"
                                                            Header="创建时间"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="60"
                                                            Binding="{Binding FileSizeDisplay}"
                                                            Header="大小"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="70"
                                                            Binding="{Binding SyncStatus}"
                                                            Header="状态"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="后端监控">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14"
                            Margin="0,0,0,12"
                            Background="#FFF7FAFC"
                            BorderBrush="#FFD7E3EF"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayProjectName}" />

                            <ComboBox Grid.Column="2"
                                      Height="26"
                                      DisplayMemberPath="WellName"
                                      ItemsSource="{Binding Wells}"
                                      SelectedItem="{Binding SelectedBackendWell}"
                                      IsEnabled="{Binding CanChangeSelectedBackendWell}"
                                      IsSynchronizedWithCurrentItem="False" />

                            <!--<Button Grid.Column="4"
                                    Width="26"
                                    Height="26"
                                    Command="{Binding LoadWellsCommand}"
                                    Content="⟳" />-->

                            <StackPanel Grid.Column="6" HorizontalAlignment="Right">
                                <TextBlock HorizontalAlignment="Right"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedBackendWellText}" />
                                <TextBlock Margin="0,4,0,0"
                                           HorizontalAlignment="Right"
                                           Foreground="#FF64748B"
                                           Text="{Binding BackendMonitorStatusText}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="SGY">
                            <Grid Margin="12">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding BackendSgyPanel.Files}">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="25" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding FileName}"
                                                            Header="文件名"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="140"
                                                            Binding="{Binding CreateTime, StringFormat=yyyy/MM/dd HH:mm:ss}"
                                                            Header="创建时间"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="ESF">
                            <Grid Margin="12">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding BackendEsfPanel.Files}">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="25" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding FileName}"
                                                            Header="文件名"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="140"
                                                            Binding="{Binding CreateTime, StringFormat=yyyy/MM/dd HH:mm:ss}"
                                                            Header="创建时间"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Column="4" Header="CSV">
                            <Grid Margin="12">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding BackendCsvPanel.Files}">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Height" Value="25" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding FileName}"
                                                            Header="文件名"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                        <DataGridTextColumn Width="140"
                                                            Binding="{Binding CreateTime, StringFormat=yyyy/MM/dd HH:mm:ss}"
                                                            Header="创建时间"
                                                            ElementStyle="{StaticResource FileGridTextColumnElementStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <Button Width="23"
                    Height="23"
                    Background="LightGray"
                    BorderThickness="0"
                    DockPanel.Dock="Left"
                    ToolTip="日志"
                    Command="{Binding ToggleLogPanelCommand}"
                    Content="{Binding LogToggleGlyph}" />
            <TextBlock Margin="10,0,0,0"
                       Foreground="#FF64748B"
                       Text="{Binding StatusMessage}" />
        </DockPanel>

        <Border Grid.Row="3"
                Margin="0,10,0,0"
                Padding="10"
                Background="#FFF8FAFC"
                BorderBrush="#FFD7E3EF"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding IsLogPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="180" />
                </Grid.RowDefinitions>
                <RichTextBox x:Name="LogRichTextBox"
                             Grid.Row="0"
                             IsReadOnly="True"
                             IsUndoEnabled="False"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas">
                    <RichTextBox.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="清空日志"
                                      Command="{Binding ClearLogCommand}" />
                        </ContextMenu>
                    </RichTextBox.ContextMenu>
                </RichTextBox>
            </Grid>
        </Border>
    </Grid>
</Window>
